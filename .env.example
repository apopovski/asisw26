# Password your editor users type when unlocking edit mode
ASISW_EDIT_PASSWORD=replace-with-edit-password

# GitHub repo write settings used by /api/publish
GITHUB_TOKEN=replace-with-github-token-with-contents-write
GITHUB_OWNER=replace-with-owner
GITHUB_REPO=replace-with-repo
GITHUB_BRANCH=main
# Optional, defaults to site-content.json
GITHUB_CONTENT_PATH=site-content.json
